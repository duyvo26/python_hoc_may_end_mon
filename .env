# ⚙️ CẤU HÌNH HỆ THỐNG PHÂN CỤM - TỐI ƯU CHO LUẬN VĂN THẠC SĨ

# 1. Ngưỡng lấy mẫu (Sampling Thresholds) 
# Mục tiêu: Cân bằng giữa tính đại diện thống kê và tốc độ xử lý (tránh treo máy)
MAX_ANALYSIS_SAMPLES=10000    # Mẫu dùng để tìm K tối ưu (theo Định luật số lớn là đủ đại diện)
MAX_VISUAL_SAMPLES=10000      # Mẫu dùng để vẽ PCA (giúp đồ thị mượt mà, không lag trình duyệt)
MAX_METRIC_SAMPLES=20000      # Mẫu dùng tính chỉ số đánh giá (Cần độ chính xác cao hơn để báo cáo)

# 2. Ngưỡng chuyển đổi thuật toán (Big Data Optimization)
# KMeans truyền thống chậm khi dữ liệu lớn, nên chuyển sang MiniBatch
MINI_BATCH_THRESHOLD=25000    # Từ 25k dòng trở lên sẽ tự động dùng MiniBatchKMeans
BATCH_SIZE=2048               # Kích thước lô tối ưu cho bộ nhớ đệm CPU

# 3. Cấu hình dải tìm K (K Range)
# Dải từ 2-10 là tiêu chuẩn học thuật để kết quả phân cụm có ý nghĩa thực tiễn
K_RANGE_MIN=2
K_RANGE_MAX=11

# 4. Trọng số biểu quyết (Weights for Voting System)
# Tăng trọng số cho các chỉ số quan trọng/độ chính xác cao hơn trong học thuật
# KMeans: Ưu tiên Silhouette và Calinski-Harabasz (Hợp với cụm hình cầu)
WEIGHT_SIL_KM=2
WEIGHT_CH_KM=2
WEIGHT_ELBOW_KM=1

# Hierarchical: Ưu tiên Davies-Bouldin (Rất tốt cho phân cụm phân cấp/BIRCH)
WEIGHT_DB_H=2
WEIGHT_SIL_H=1
WEIGHT_CH_H=1
